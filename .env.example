# nbx-guard environment configuration (copy to your shell / .env and edit)

# NetBox base URL (no trailing slash).
export NETBOX_URL="http://localhost:8000"

# NetBox API token. Required for get / inspect / apply / restore.
export NETBOX_TOKEN=""

# Where local state (plans / backups / approvals / audit) is stored.
export NBX_GUARD_STATE_DIR=".nbx-guard"

# Set to 1/true to route writes through the NetBox Branching plugin.
export NBX_GUARD_BRANCHING="0"

# Optional active branch schema id when branching is enabled.
# export NBX_GUARD_BRANCH=""
