# nbx-guard 环境配置（复制到你的 shell / .env 后修改）

# NetBox 基础 URL（末尾不带斜杠）。
export NETBOX_URL="http://localhost:8000"

# NetBox API token。get / inspect / plan / apply / restore 必需。
export NETBOX_TOKEN=""

# 本地状态（plans / backups / approvals / audit）的存放位置。
export NBX_GUARD_STATE_DIR=".nbx-guard"

# 单次 NetBox 请求的连接超时（毫秒），NetBox 不可达时避免 CLI 永久挂起；0 关闭。
export NBX_GUARD_HTTP_TIMEOUT_MS="15000"

# 设为 1/true 可将写入路由进 NetBox Branching 插件。
export NBX_GUARD_BRANCHING="0"

# 启用分支时可选的生效分支 schema id。
# export NBX_GUARD_BRANCH=""

# --- 算子治理扩展（人工运维方控制；agent 不应设置）-----------------------------
# 在默认拒绝之外显式放行更多受治理类型/可写字段。等价地也可写进
# ~/.nbx-guard/config.json（见 docs/src/policy.md）。密钥仍只走上面的环境变量。
# export NBX_GUARD_EXTRA_RESOURCES="site=dcim/sites,tenant=tenancy/tenants"
# export NBX_GUARD_ALLOWED_FIELDS="serial,asset_tag"
# export NBX_GUARD_HIGH_RISK_FIELDS="tenant"
# 追加读敏感字段（默认读取脱敏，整对象读取需 approve-read）。
# export NBX_GUARD_READ_SENSITIVE_FIELDS="serial"
# 开启 `nbxg create` 的类型（逗号/空格分隔，* 表示任意类型）。默认空=禁止创建；每次创建仍需审批。
# export NBX_GUARD_CREATABLE_RESOURCES="site,vlan"
# 算子配置文件路径覆盖（默认 ~/.nbx-guard/config.json）。
# export NBX_GUARD_CONFIG="$HOME/.nbx-guard/config.json"
