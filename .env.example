# nbx-guard 环境配置（复制到你的 shell / .env 后修改）

# NetBox 基础 URL（末尾不带斜杠）。
export NETBOX_URL="http://localhost:8000"

# NetBox API token。get / inspect / apply / restore 必需。
export NETBOX_TOKEN=""

# 本地状态（plans / backups / approvals / audit）的存放位置。
export NBX_GUARD_STATE_DIR=".nbx-guard"

# 设为 1/true 可将写入路由进 NetBox Branching 插件。
export NBX_GUARD_BRANCHING="0"

# 启用分支时可选的生效分支 schema id。
# export NBX_GUARD_BRANCH=""
